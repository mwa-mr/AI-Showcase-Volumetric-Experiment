# Ignore Visual Studio or Visual StudioCode temporary files, build results, and
# files generated by popular Visual Studio Code add-ons.

.vs/
.vscode/
out/
build/

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Compiled resources
*.aps