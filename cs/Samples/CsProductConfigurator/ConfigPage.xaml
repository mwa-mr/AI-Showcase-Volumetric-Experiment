<?xml version="1.0" encoding="utf-8"?>
<Page  
    x:Class="Volumetric.Samples.ProductConfigurator.ConfigPage"  
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
    xmlns:local="using:Volumetric.Samples.ProductConfigurator"  
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"  
    xmlns:wv2="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"  
    Loaded="Page_Loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="#f3f3f3">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Principal content -->
            <RowDefinition Height="80" />
            <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Padding="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="550" />
                    <ColumnDefinition Width="550" />
                </Grid.ColumnDefinitions>

                <!-- LeftColumn -->
                <StackPanel Grid.Column="0" Spacing="16">

                    <!-- Color Section -->
                    <Border 
                        MinHeight="320"
                        CornerRadius="16" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        Background="#f6f6f6" 
                        Padding="18"
                        Margin="12,0,12,6">

                        <Border>
                            <StackPanel Height="325">

                                <!-- Section Title -->
                                <Grid Background="#f6f6f6" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <!-- Title column -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Buttons menu column -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Title -->
                                    <Border 
                                        Background="#F4F4F4" 
                                        BorderBrush="#E5E5E5" 
                                        BorderThickness="1" 
                                        CornerRadius="20"
                                         Grid.Column="0"
                                        Padding="0">

                                        <TextBlock Text="Colors" FontSize="14" 
                                            VerticalAlignment="Center" 
                                            HorizontalAlignment="Left" 
                                            Margin="15,6"/>
                                    </Border>

                                    <!-- Right Menu -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ToggleButton 
                                                Style="{StaticResource CustomToggleButtonStyle}"
                                                x:Name="HeadbandToggle"
                                                Content="Headband"
                                                Click="HeadbandToggle_Click"
                                                CornerRadius="16,0,0,16"
                                                BorderThickness="1,1,0,1"
                                                IsChecked="True"
                                                Padding="15,8"
                                                Margin="0"/>
                                            <ToggleButton
                                                Style="{StaticResource CustomToggleButtonStyle}"
                                                Content="Speakers"
                                                x:Name="SpeakersToggle"
                                                Click="SpeakersToggle_Click"
                                                CornerRadius="0,16,16,0"
                                                BorderThickness="0,1,1,1"
                                                Padding="15,8"
                                                IsChecked="False"
                                                Margin="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Color Picker -->
                                <Border Padding="0, 24">
                                    
                                    <ColorPicker  
                                        x:Name="ElementColorPicker"
                                        Orientation="Horizontal"  
                                        HorizontalAlignment="Left"  
                                        Foreground="#777777"  
                                        VerticalAlignment="Top"  
                                        ColorSpectrumShape="Box"  
                                        ColorSpectrumComponents="HueSaturation"  
                                        Margin="0"  
                                        Height="Auto"
  >
                                        <ColorPicker.Resources>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Width" Value="70"/>
                                                <Setter Property="MaxWidth" Value="70"/>
                                                <Setter Property="MinWidth" Value="70"/>
                                                <Setter Property="CornerRadius" Value="16"/>
                                                <Setter Property="Padding" Value="6"/>
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Background" Value="White"/>
                                            </Style>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="Width" Value="70"/>
                                                <Setter Property="MaxWidth" Value="70"/>
                                                <Setter Property="MinWidth" Value="70"/>
                                                <Setter Property="CornerRadius" Value="16"/>
                                                <Setter Property="Padding" Value="6"/>
                                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Background" Value="White"/>
                                            </Style>

                                            <SolidColorBrush x:Key="TextControlForeground" Color="#777777"/>
                                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#777777"/>
                                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#777777"/>
                                        </ColorPicker.Resources>
                                    </ColorPicker>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Border>
                    <!-- Texture Section -->
                    <Border 
                        MinHeight="220"
                        CornerRadius="16" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        Background="#f6f6f6" 
                        Padding="18" Margin="12, 0">

                        <StackPanel>
                            <!-- Section Title -->
                            <Grid Background="#f6f6f6" Height="40" VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <!-- Title column -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Buttons menu column -->
                                </Grid.ColumnDefinitions>

                                <!-- Left Title -->
                                <Border 
                                    Background="#F4F4F4" 
                                    BorderBrush="#E5E5E5" 
                                    BorderThickness="1" 
                                    CornerRadius="20"
                                    Grid.Column="0"
                                    Padding="0">

                                    <TextBlock Text="Textures" FontSize="14" 
                                         VerticalAlignment="Center" 
                                         HorizontalAlignment="Left" 
                                         Margin="15,6"/>
                                </Border>
                            </Grid>
                            <ScrollViewer 
                                x:Name="ImageScrollViewer" HorizontalScrollMode="Enabled"  
                                HorizontalScrollBarVisibility="Auto"  
                                VerticalScrollMode="Disabled"  
                                IsScrollInertiaEnabled="True"  
                                IsHitTestVisible="True" 
                                Height="130"
                                Margin="0,10,0,0">

                                <StackPanel x:Name="ImageTogglePanel" Orientation="Horizontal" Spacing="8" />
                            </ScrollViewer>

                            <ScrollBar 
                                Orientation="Horizontal"
                                Height="1"
                                Background="#f6f6f6"
                                Foreground="#c5c5c5"
                                CornerRadius="1"
                                Margin="0,-8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="1" Spacing="16">
                    <!-- Accessories -->
                    <Border 
                        MinHeight="320"
                        CornerRadius="16" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1" 
                        Background="#f6f6f6" 
                        Padding="18"
                        Margin="12,0,12,6">

                        <Border>
                            <StackPanel Height="325">

                                <!-- Section Title -->
                                <Grid Background="#f6f6f6" Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <!-- Title column -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Buttons menu column -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Title -->
                                    <Border 
                                        Background="#F4F4F4" 
                                        BorderBrush="#E5E5E5" 
                                        BorderThickness="1" 
                                        CornerRadius="20"
                                        Grid.Column="0"
                                        Padding="0">

                                        <TextBlock Text="Accessories" FontSize="14" 
                                            VerticalAlignment="Center" 
                                            HorizontalAlignment="Left" 
                                            Margin="15,6"/>
                                    </Border>
                                </Grid>

                                <!-- selector -->
                                <Border Padding="0, 12">
                                    <StackPanel>
                                        <ScrollViewer 
                                            x:Name="AccessoriesScrollViewer" 
                                            HorizontalScrollMode="Enabled"  
                                            HorizontalScrollBarVisibility="Auto"  
                                            VerticalScrollMode="Disabled"  
                                            IsScrollInertiaEnabled="True"  
                                            IsHitTestVisible="True" 
                                            Height="270"
                                            Margin="0,0,0,0">

                                            <StackPanel 
                                                x:Name="AccessoriesImageTogglePanel" 
                                                Orientation="Horizontal" 
                                                Spacing="8">
                                            </StackPanel>
                                        </ScrollViewer>

                                        <ScrollBar 
                                            Orientation="Horizontal"
                                            Height="1"
                                            Background="#f6f6f6"
                                            Foreground="#c5c5c5"
                                            CornerRadius="1"
                                            Margin="0,-8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Accessories -->
                    <Border 
                          Height="220"
                          CornerRadius="16" 
                          BorderBrush="#E0E0E0" 
                          BorderThickness="1" 
                          Background="#f6f6f6" 
                          Padding="18"
                          Margin="12,0,12,0">

                        <Grid Width="Auto" Height="Auto">
                            <Grid Width="Auto" Height="Auto">

                                <Image 
                                    x:Name="HeadsetHeadphone"
                                    Source="/Assets/Images/headphone.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>

                                <Image 
                                    x:Name="HeadsetHeadband"
                                    Source="/Assets/Images/headBand.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>

                                <Image 
                                    x:Name="HeadsetSpeaker"
                                    Source="/Assets/Images/speaker.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>

                                <Image 
                                    x:Name="HeadsetTexture"
                                    Source="/Assets/Images/earCushion_2.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>

                                <!-- Top image -->
                                <Image 
                                    x:Name="Accessory1Image"
                                    Source="ms-appx:///Assets/Images/headset3.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Visibility="Collapsed"
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>
                                <Image 
                                    x:Name="Accessory2Image"
                                    Source="ms-appx:///Assets/Images/headset2.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Visibility="Collapsed"
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>
                                <Image 
                                    x:Name="Accessory3Image"
                                    Source="ms-appx:///Assets/Images/headset4.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Visibility="Collapsed"
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>
                                <Image 
                                    x:Name="Accessory4Image"
                                    Source="ms-appx:///Assets/Images/headset3.png" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top" 
                                    Visibility="Collapsed"
                                    Stretch="Uniform"
                                    Margin="0,0,0,0"/>
                            </Grid>

                            <Border 
                                Background="#F4F4F4" 
                                BorderBrush="#E5E5E5" 
                                BorderThickness="1" 
                                CornerRadius="20"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Grid.Column="0"
                                Width="80"
                                Height="40"
                                Padding="0">

                                <TextBlock Text="Preview" FontSize="14" 
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Left" 
                                    Margin="15,6"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#eaeaea">
            <Grid Height="60" Width="1000" Background="Transparent" Padding="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Text -->
                <TextBlock 
                        Text="Click `Deploy` to show it in Mixed Reality" 
                        VerticalAlignment="Center" 
                        FontSize="16"
                        Foreground="Black" />

                <!-- Right Button -->
                <Button 
                    x:Name ="deployButton" 
                    Width="140"
                    Height="40"
                    Margin="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Grid.Column="1"
                    Background="Black"
                    Foreground="White"
                    Click="deployButton_Pressed"
                    BorderBrush="Black"
                    BorderThickness="0"
                    CornerRadius="20">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Black" CornerRadius="20">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#333333"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed"/>
                                        <VisualState x:Name="Loading">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="Gray"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="Gray"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Opacity">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="0.5"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <ContentPresenter 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE895;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" FontSize="14" />
                        <TextBlock x:Name="deployText" Text="Deploy" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>  
</Page>
