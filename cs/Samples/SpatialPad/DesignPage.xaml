<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Volumetric.Samples.SpatialPad.DesignPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Volumetric.Samples.SpatialPad"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    xmlns:helpers="using:Volumetric.Samples.SpatialPad.Helpers" >

    <Page.Resources>
        <helpers:PadNumberConverter x:Key="PadNumberConverter" />
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
        <helpers:SelectedToBrushConverter x:Key="SelectedToBrushConverter" />
        <helpers:SelectedToForegroundConverter x:Key="SelectedToForegroundConverter" />
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="#f3f3f3" MinWidth="640">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel x:Name="RootStack" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,20">
                    <ItemsControl x:Name="KeypadButtons" ItemsSource="{x:Bind _keypads, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:KeypadData">
                                <Button 
                                    Content="{x:Bind Index, Converter={StaticResource PadNumberConverter}}"
                                    Tag="{x:Bind Index}"
                                    Background="{x:Bind IsSelected, Converter={StaticResource SelectedToBrushConverter}}"
                                    Foreground="{x:Bind IsSelected, Converter={StaticResource SelectedToForegroundConverter}}"
                                    Click="ChangeKeypadButton_Click" 
                                    BorderBrush="#F9F9F9"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="12,6"
                                    Margin="2,0"
                                    MinWidth="70" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <ItemsControl x:Name="SlotGrid" ItemsSource="{x:Bind _keypadData.Slots, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid 
                                 Orientation="Horizontal"
                                 MaximumRowsOrColumns="3"
                                 ItemWidth="150"
                                 ItemHeight="150"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:Slot">
                            <Border
                                Tapped="Slot_Tapped"
                                x:Name="SlotBorder"  
                                Background="Transparent"
                                Margin="0"
                                PointerEntered="SlotBorder_PointerEntered"
                                PointerExited="SlotBorder_PointerExited"
                                Loaded="Border_Loaded">
                                <Grid>
                                    <Image 
                                        x:Name="ShadowImage"
                                        Source="{x:Bind ButtonImageShadow, Mode=OneWay}" 
                                        Stretch="UniformToFill"
                                        Opacity="1"/>

                                    <Image 
                                        x:Name="HoverShadowImage"
                                        Source="{x:Bind ButtonImageHoverShadow, Mode=OneWay}" 
                                        Stretch="UniformToFill"
                                        RenderTransformOrigin="0.5,0.5"
                                        Opacity="0">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="1.00" ScaleY="1.00"/>
                                        </Image.RenderTransform>
                                    </Image>
                                    <Image 
                                        x:Name="ButtonImage"
                                        Source="{x:Bind ButtonImageNormal, Mode=OneWay}" 
                                        RenderTransformOrigin="0.5,0.5"
                                        Stretch="UniformToFill">
                                        <Image.RenderTransform>
                                            <ScaleTransform ScaleX="1.00" ScaleY="1.00"/>
                                        </Image.RenderTransform>
                                    </Image>
                                    <Button
                                        x:Name="AddButton"
                                        Width="32"
                                        Height="32"
                                        Visibility="Collapsed"
                                        Opacity="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="Black"
                                        Foreground="White"
                                        FontSize="16"
                                        FontWeight="Medium"
                                        Padding="0"
                                        Content="+"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="15"
                                        IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#eaeaea">
            <Grid Height="60" MaxWidth="1000" Background="Transparent" Padding="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock 
                    Text="Click `Deploy` to show it in Mixed Reality" 
                    VerticalAlignment="Center" 
                    FontSize="16"
                    Grid.Column="0"
                    Margin="20,0,0,0"
                    Foreground="Black" />

                <Button 
                    x:Name ="deployButton" 
                    Width="140"
                    Height="40"
                    Margin="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Grid.Column="2"
                    Background="Black"
                    Foreground="White"
                    Click="deployButton_Pressed"
                    BorderBrush="Black"
                    BorderThickness="0"
                    CornerRadius="20">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Black" CornerRadius="20">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#333333"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed"/>
                                        <VisualState x:Name="Loading">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="Gray"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="Gray"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames 
                                                    Storyboard.TargetName="RootGrid"
                                                    Storyboard.TargetProperty="Opacity">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="0.5"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <ContentPresenter 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE895;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" FontSize="14" />
                        <TextBlock x:Name="deployText" Text="Deploy" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="30,0,0,0"
                    Width="150" >
                    <ToggleSwitch 
                        x:Name="LightPadToggle"
                        Toggled="LightPadToggle_Toggled"
                        VerticalAlignment="Center"
                        OffContent=""
                        OnContent=""
                        IsOn="{x:Bind _keypadData.DarkMode, Mode=TwoWay}"
                        Margin="0" />

                    <TextBlock 
                        Text="Dark Pad"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="Black"
                        Margin="-100,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid 
            x:Name="Overlay"
            Background="#00000080"  
            Visibility="Collapsed"
            Tapped="Overlay_Tapped"
            IsHitTestVisible="False"/>

        <Popup 
             x:Name="PopupWindow" 
             Closed="OptionsPopup_Dismiss_Closed"
             HorizontalAlignment="Center" 
             VerticalAlignment="Center" 
             Margin="0" >
            <Border x:Name="PopupBorder" Background="#33ffffff">
                <Grid>

                    <Button 
                        x:Name="TopButton" 
                        Width="30" 
                        Height="30"
                        Padding="4"
                        Background="Black" 
                        Foreground="White" 
                        CornerRadius="15"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Bottom" 
                        Margin="0,0,0,28" 
                        Opacity="0" 
                        RenderTransformOrigin="0.5,0.5" 
                        Click="TopButton_Click">
                        <Button.RenderTransform>
                            <TranslateTransform x:Name="TopButtonTransform" />
                        </Button.RenderTransform>
                        <FontIcon Glyph="&#xE74D;" FontSize="11" />
                    </Button>

                    <Button x:Name="LeftButton" Width="40" Height="40" Background="Black" Foreground="White" CornerRadius="20"
                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0" RenderTransformOrigin="0.5,0.5" Click="LeftButton_Click">
                        <Button.RenderTransform>
                            <TranslateTransform x:Name="LeftButtonTransform" />
                        </Button.RenderTransform>
                        <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                    </Button>

                    <Button x:Name="RightButton" Width="40" Height="40" Background="Black" Foreground="White" CornerRadius="20"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0" RenderTransformOrigin="0.5,0.5" Click="RightButton_Click">
                        <Button.RenderTransform>
                            <TranslateTransform x:Name="RightButtonTransform" />
                        </Button.RenderTransform>
                        <FontIcon Glyph="&#xE72D;" FontSize="12"/>
                    </Button>
                </Grid>
            </Border>
        </Popup>

        <Popup 
             x:Name="SelectionPopup" 
             IsLightDismissEnabled="True"
             Closed="SelectionPopup_Dismiss_Closed" >

            <StackPanel Background="Transparent">
                <Border x:Name="ColorPopupBorder" Background="White" CornerRadius="16" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <FontIcon 
                             Grid.Column="0" 
                             Glyph="&#xE790;" 
                             FontFamily="Segoe MDL2 Assets" 
                             FontSize="22" 
                             Margin="12,0,0,0" 
                             VerticalAlignment="Center"
                             HorizontalAlignment="Left"
                             Foreground="#252525"
                             ToolTipService.ToolTip="Pick your Color" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1">
                            <ItemsControl x:Name="SelectionGrid">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid 
                                             Orientation="Horizontal"
                                             MaximumRowsOrColumns="6"
                                             HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Button Width="24" Height="24" Margin="5" Background="{Binding}" BorderThickness="1" CornerRadius="12" Click="SetNewColor">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>

                                                        <Border x:Name="ButtonBorder"
                                                             Background="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             BorderThickness="{TemplateBinding BorderThickness}"
                                                             CornerRadius="16">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>

                                                        <VisualStateManager.VisualStateGroups>
                                                            <VisualStateGroup x:Name="CommonStates">
                                                                <VisualState x:Name="Normal"/>
                                                                <VisualState x:Name="PointerOver">
                                                                    <VisualState.Setters>
                                                                        <Setter Target="ButtonBorder.BorderBrush" Value="#99999999"/>
                                                                        <Setter Target="ButtonBorder.BorderThickness" Value="1"/>
                                                                    </VisualState.Setters>
                                                                </VisualState>
                                                                <VisualState x:Name="Pressed"/>
                                                                <VisualState x:Name="Disabled"/>
                                                            </VisualStateGroup>
                                                        </VisualStateManager.VisualStateGroups>
                                                    </Grid>

                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
                <Border x:Name="ShapePopupBorder" 
                     Background="White" 
                     CornerRadius="16" 
                     Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" >
                        <ItemsControl x:Name="SelectionShape">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                        MaximumRowsOrColumns="2"
                                        ItemWidth="160"
                                        ItemHeight="160"
                                        HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:ButtonChoice">
                                    <Button Click="OnShapeSelected"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         CornerRadius="16">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Border x:Name="ButtonBorder"
                                                        Background="{TemplateBinding BorderBrush}"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="3"
                                                        CornerRadius="16">
                                                        <Grid>

                                                            <Image Source="{Binding ShadowImage}" Stretch="UniformToFill"/>
                                                            <Image Source="{Binding NormalImage}" Opacity="0.5" Stretch="UniformToFill"/>
                                                            <TextBlock 
                                                                Text="{Binding KeyName}" 
                                                                VerticalAlignment="Bottom" 
                                                                HorizontalAlignment="Left"
                                                                Margin="8"
                                                                FontSize="13"
                                                                FontWeight="Medium"
                                                                Foreground="Black" />
                                                        </Grid>
                                                    </Border>

                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="PointerOver">
                                                                <VisualState.Setters>
                                                                    <Setter Target="ButtonBorder.BorderBrush" Value="#22999999"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed"/>
                                                            <VisualState x:Name="Disabled"/>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Grid>

                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Popup>
        <Popup
            x:Name="ShortcutPopup"
            IsLightDismissEnabled="False"
            Closed="ShortcutPopup_Dismiss_Closed" >

            <Grid x:Name="PopupContentRoot" Opacity="0">
                <StackPanel Background="Transparent">

                    <Border x:Name="ShortcutPopupBorder" 
                        Background="White"
                        CornerRadius="24"
                        Width="300"
                        Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <Image 
                                Source="Assets/Images/app.png"
                                Grid.Column="0" 
                                Width="20"
                                Height="20"
                                ToolTipService.ToolTip="Pick your App"
                                Margin="12,0,0,0" 
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Stretch="Uniform"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1">
                                <ItemsControl x:Name="ShortcutSelectionGrid">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid 
                                                 Orientation="Horizontal"
                                                 MaximumRowsOrColumns="6"
                                                 HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:ShortcutAppVisual">
                                            <Button Click="AppSelector_SelectionChanged"
                                                Tag="{x:Bind App}"
                                                Background="{x:Bind ColorBrush}"
                                                Padding="0"
                                                BorderBrush="Blue"
                                                BorderThickness="0"
                                                Margin="4"
                                                CornerRadius="16">

                                                <Border Width="28" Height="28" CornerRadius="14">
                                                    <Image Source="{x:Bind ImagePath}" Stretch="UniformToFill">
                                                        <Image.RenderTransform>
                                                            <ScaleTransform ScaleX="1.6" ScaleY="1.6" CenterX="14" CenterY="14" />
                                                        </Image.RenderTransform>
                                                    </Image>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Border 
                        x:Name="ShortcutBorder" 
                        Background="White" 
                        CornerRadius="16" 
                        Margin="0, 10, 0, 0"
                        Padding="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="235">
                            <ListView 
                                x:Name="ShortcutsListView" 
                                IsItemClickEnabled="True"
                                ItemClick="ShortcutsListView_ItemClick"
                                Margin="2">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:Shortcut">
                                        <Border x:Name="HighlightBorder"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="2"
                                            Margin="2"
                                            BorderBrush="Transparent"
                                            Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Text="{x:Bind Description}"
                                                    Tag="{x:Bind Description}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    MaxWidth="150"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Text="{x:Bind KeysDescription}"
                                                    FontSize="12"
                                                    Foreground="Gray"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    MaxWidth="90"
                                                    Margin="5,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Grid>
        </Popup>
    </Grid>
</Page>
