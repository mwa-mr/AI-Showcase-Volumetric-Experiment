# Line endings
#--------------------------------------------------------------------------------------------------------------------------------------------------------------

# Set default behavior to automatically normalize line endings. Use 'git ls-files --eol' to see status of all files in repo.
* text=auto

# Declare files that will always have Windows CRLF line endings on checkout
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.csproj  text eol=crlf
*.sln     text eol=crlf
*.vcproj  text eol=crlf
*.vcxproj text eol=crlf

# Declare files that will always have Unix LF line endings on checkout
*.sh      text eol=lf

# Unity files
*.unity   text eol=lf
*.asset   text eol=lf
*.meta    text eol=lf
*.prefab  text eol=lf

# Godot Files
*.gdextension text eol=lf
*.godot   text eol=lf
*.import  text eol=lf
*.tres    text eol=lf
*.tscn    text eol=lf
*.uid     text eol=lf

