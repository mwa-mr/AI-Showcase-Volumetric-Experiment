<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Volumetric.Samples.ProductConfigurator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Volumetric.Samples.ProductConfigurator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ProductConfigurator">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <!-- TitleBar -->
            <RowDefinition Height="*"/>
            <!-- RootFrame -->
        </Grid.RowDefinitions>

        <Grid x:Name="WindowTitleBar" Background="#f6f6f6" Grid.Row="0" Height="32">
            <Image Source="Assets/Images/favicon.png"
                   HorizontalAlignment="Left" 
                   Width="16" Height="16" 
                   Margin="16,0"/>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="32,0" Padding="10,0" Text="Product Configurator" FontSize="12" Foreground="Black"/>
        </Grid>
        <Frame x:Name="RootFrame" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="1" />
    </Grid>
</Window>
