<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CsMaterialExplorer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CsMaterialExplorer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"    
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid DataContext="{x:Bind _viewModel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2">
            <muxc:AppBarButton
                Width="160"
                Icon="OpenFile"
                Label="Open GLB File ..."
                Click="OpenFile_Click" />

            <TextBlock Text="{Binding FileUri}" VerticalAlignment="Center"/>
        </StackPanel>
        
        <muxc:AppBarButton
            Grid.Column="2"
            Width="160"
            Icon="Cancel"
            Label="Close"
            Click="Close_Click" 
            HorizontalAlignment="Right"/>

        <Rectangle Grid.ColumnSpan="2" Grid.Column="0" Grid.Row="0" Height="2" VerticalAlignment="Bottom" Fill="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}" />

        <ListView x:Name="ListView"
                  Grid.Column="0" Grid.Row="1" Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}"
                  SelectionMode="Single"
                  SelectedValue="{Binding SelectedValue, Mode=TwoWay}"
                  MinWidth="100"
                  MaxWidth="300"
                  ItemsSource="{Binding Materials}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0 10">
                        <TextBlock Text="{Binding MaterialName}" TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ScrollView Grid.Column="1" Grid.Row="1" HorizontalScrollMode="Disabled" VerticalScrollMode="Auto">
            <Grid DataContext="{Binding ElementName=ListView, Path=SelectedValue}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/> <!-- Material name -->
                    <RowDefinition Height="Auto"/> <!-- Material name -->
                    <RowDefinition Height="Auto"/> <!-- Meterial type -->
                    <RowDefinition Height="Auto"/> <!-- BaseColor.r -->
                    <RowDefinition Height="Auto"/> <!-- BaseColor.g -->
                    <RowDefinition Height="Auto"/> <!-- BaseColor.b -->
                    <RowDefinition Height="Auto"/> <!-- BaseColor.a -->
                    <RowDefinition Height="Auto"/> <!-- BaseColor Texture --> 
                    <RowDefinition Height="Auto"/> <!-- Metallic factor -->
                    <RowDefinition Height="Auto"/> <!-- Roughness factor -->
                    <RowDefinition Height="Auto"/> <!-- MetallicRoughness Texture -->
                    <RowDefinition Height="Auto"/> <!-- Normal Scale -->
                    <RowDefinition Height="Auto"/> <!-- Normal Texture -->
                    <RowDefinition Height="Auto"/> <!-- Occlusion Strength -->
                    <RowDefinition Height="Auto"/> <!-- Occlusion Texture -->
                    <RowDefinition Height="Auto"/> <!-- Emissive Texture -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style x:Key="PropertyStyle" TargetType="TextBlock">
                        <Setter Property="Margin" Value="20 10" />
                        <Setter Property="HorizontalAlignment" Value="Right" />
                    </Style>
                    <Style TargetType="muxc:NumberBox">
                        <Setter Property="Width" Value="160" />
                        <Setter Property="Margin" Value="20 10" />
                        <Setter Property="Minimum" Value="0" />
                        <Setter Property="Maximum" Value="2" />
                        <Setter Property="SmallChange" Value="0.1" />
                        <Setter Property="LargeChange" Value="0.5" />
                        <Setter Property="HorizontalAlignment" Value="Left" />
                        <Setter Property="SpinButtonPlacementMode" Value="Inline" />
                    </Style>
                    <Style TargetType="Slider">
                        <Setter Property="Margin" Value="20 10" />
                        <Setter Property="Minimum" Value="0" />
                        <Setter Property="Maximum" Value="1" />
                        <Setter Property="SmallChange" Value="0.1" />
                        <Setter Property="LargeChange" Value="0.5" />
                        <Setter Property="StepFrequency" Value="0.1" />
                    </Style>
                    <local:TextureStatusToIconConverter x:Key="TextureStatusToIconConverter"/>
                    <local:TextureStatusToColorConverter x:Key="TextureStatusToColorConverter"/>
                </Grid.Resources>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Material Name:" Style="{StaticResource PropertyStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"  Text="{Binding MaterialName}" />

                <TextBlock Grid.Row="2" Grid.Column="0"  Text="Material Type:" Style="{StaticResource PropertyStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"  Text="{Binding MaterialType}" />

                <TextBlock Grid.Row="3" Grid.Column="0"  Text="BaseColorFactor[R]:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="3" Grid.Column="1" Value="{Binding BaseColorFactorR, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}"/>
                <Slider Grid.Row="3" Grid.Column="2" Value="{Binding BaseColorFactorR, Mode=TwoWay}"/>

                <TextBlock Grid.Row="4" Grid.Column="0"  Text="BaseColorFactor[G]:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="4" Grid.Column="1" Value="{Binding BaseColorFactorG, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" />
                <Slider Grid.Row="4" Grid.Column="2" Value="{Binding BaseColorFactorG, Mode=TwoWay}"/>

                <TextBlock Grid.Row="5" Grid.Column="0"  Text="BaseColorFactor[B]:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="5" Grid.Column="1" Value="{Binding BaseColorFactorB, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" />
                <Slider Grid.Row="5" Grid.Column="2" Value="{Binding BaseColorFactorB, Mode=TwoWay}"/>

                <TextBlock Grid.Row="6" Grid.Column="0"  Text="BaseColorFactor[A]:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="6" Grid.Column="1" Value="{Binding BaseColorFactorA, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" />
                <Slider Grid.Row="6" Grid.Column="2" Value="{Binding BaseColorFactorA, Mode=TwoWay}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="BaseColor Texture:" Style="{StaticResource PropertyStyle}" />
                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Center">
                    <Button Click="SelectBaseColorTexture_Click" Width="40" Height="40" ToolTipService.ToolTip="Browse for BaseColor Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button Click="ResetBaseColorTexture_Click" Width="40" Height="40" Margin="5,0,0,0" ToolTipService.ToolTip="Reset BaseColor Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE777;" FontSize="14" />
                    </Button>
                    <FontIcon Glyph="{Binding BaseColorTextureStatus, Converter={StaticResource TextureStatusToIconConverter}}"
                              Foreground="{Binding BaseColorTextureStatus, Converter={StaticResource TextureStatusToColorConverter}}"
                              ToolTipService.ToolTip="{Binding BaseColorTextureError}"
                              Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
                <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding BaseColorTextureUri, Mode=OneWay}" VerticalAlignment="Center" Margin="10,0"/>

                <TextBlock Grid.Row="8" Grid.Column="0"  Text="Metallic Factor:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="8" Grid.Column="1" Value="{Binding MetallicFactor, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" />
                <Slider Grid.Row="8" Grid.Column="2" Value="{Binding MetallicFactor, Mode=TwoWay}"/>

                <TextBlock Grid.Row="9" Grid.Column="0"  Text="Roughness Factor:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="9" Grid.Column="1" Value="{Binding RoughnessFactor, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" />
                <Slider Grid.Row="9" Grid.Column="2" Value="{Binding RoughnessFactor, Mode=TwoWay}"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="MetallicRoughness Texture:" Style="{StaticResource PropertyStyle}" />
                <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Center">
                    <Button Click="SelectMetallicRoughnessTexture_Click" Width="40" Height="40" ToolTipService.ToolTip="Browse for MetallicRoughness Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button Click="ResetMetallicRoughnessTexture_Click" Width="40" Height="40" Margin="5,0,0,0" ToolTipService.ToolTip="Reset MetallicRoughness Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE777;" FontSize="14"/>
                    </Button>
                    <FontIcon Glyph="{Binding MetallicRoughnessTextureStatus, Converter={StaticResource TextureStatusToIconConverter}}"
                   Foreground="{Binding MetallicRoughnessTextureStatus, Converter={StaticResource TextureStatusToColorConverter}}"
                   ToolTipService.ToolTip="{Binding MetallicRoughnessTextureError}"
                   Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
                <TextBlock Grid.Row="10" Grid.Column="2" Text="{Binding MetallicRoughnessTextureUri, Mode=OneWay}" VerticalAlignment="Center" Margin="10,0"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Normal Scale:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="11" Grid.Column="1" Value="{Binding NormalScale, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" Maximum="1"/>
                <Slider Grid.Row="11" Grid.Column="2" Value="{Binding NormalScale, Mode=TwoWay}" Maximum="1"/>
            
                <TextBlock Grid.Row="12" Grid.Column="0" Text="Normal Texture:" Style="{StaticResource PropertyStyle}" />
                <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Center">
                    <Button Click="SelectNormalTexture_Click" Width="40" Height="40" ToolTipService.ToolTip="Browse for Normal Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button Click="ResetNormalTexture_Click" Width="40" Height="40" Margin="5,0,0,0" ToolTipService.ToolTip="Reset Normal Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE777;" FontSize="14"/>
                    </Button>
                    <FontIcon Glyph="{Binding NormalTextureStatus, Converter={StaticResource TextureStatusToIconConverter}}"
                              Foreground="{Binding NormalTextureStatus, Converter={StaticResource TextureStatusToColorConverter}}"
                              ToolTipService.ToolTip="{Binding NormalTextureError}"
                              Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
                <TextBlock Grid.Row="12" Grid.Column="2" Text="{Binding NormalTextureUri, Mode=OneWay}" VerticalAlignment="Center" Margin="10,0"/>

                <TextBlock Grid.Row="13" Grid.Column="0" Text="Occlusion Strength:" Style="{StaticResource PropertyStyle}" />
                <NumberBox Grid.Row="13" Grid.Column="1" Value="{Binding OcclusionStrength, Mode=TwoWay}" NumberFormatter="{x:Bind _numberFormatter}" Maximum="1"/>
                <Slider Grid.Row="13" Grid.Column="2" Value="{Binding OcclusionStrength, Mode=TwoWay}" Maximum="1"/>
            
                <TextBlock Grid.Row="14" Grid.Column="0" Text="Occlusion Texture:" Style="{StaticResource PropertyStyle}" />
                <StackPanel Grid.Row="14" Grid.Column="1" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Center">
                    <Button Click="SelectOcclusionTexture_Click" Width="40" Height="40" ToolTipService.ToolTip="Browse for Occlusion Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    </Button>
                    <Button Click="ResetOcclusionTexture_Click" Width="40" Height="40" Margin="5,0,0,0" ToolTipService.ToolTip="Reset Occlusion Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE777;" FontSize="14"/>
                    </Button>
                    <FontIcon Glyph="{Binding OcclusionTextureStatus, Converter={StaticResource TextureStatusToIconConverter}}"
                              Foreground="{Binding OcclusionTextureStatus, Converter={StaticResource TextureStatusToColorConverter}}"
                              ToolTipService.ToolTip="{Binding OcclusionTextureError}"
                              Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
                <TextBlock Grid.Row="14" Grid.Column="2" Text="{Binding OcclusionTextureUri, Mode=OneWay}" VerticalAlignment="Center" Margin="10,0"/>

                <TextBlock Grid.Row="15" Grid.Column="0" Text="Emissive Texture:" Style="{StaticResource PropertyStyle}" />
                <StackPanel Grid.Row="15" Grid.Column="1" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Center">
                    <Button Click="SelectEmissiveTexture_Click" Width="40" Height="40" ToolTipService.ToolTip="Browse for Emissive Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                    </Button>
                    <Button Click="ResetEmissiveTexture_Click" Width="40" Height="40" Margin="5,0,0,0" ToolTipService.ToolTip="Reset Emissive Texture" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE777;" FontSize="14"/>
                    </Button>
                    <FontIcon Glyph="{Binding EmissiveTextureStatus, Converter={StaticResource TextureStatusToIconConverter}}"
                              Foreground="{Binding EmissiveTextureStatus, Converter={StaticResource TextureStatusToColorConverter}}"
                              ToolTipService.ToolTip="{Binding EmissiveTextureError}"
                              Margin="15,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
                <TextBlock Grid.Row="15" Grid.Column="2" Text="{Binding EmissiveTextureUri, Mode=OneWay}" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>
        </ScrollView>
    </Grid>
</Window>
